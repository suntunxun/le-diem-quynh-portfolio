---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
	</head>
	<body>
		<main>
			<div class="card">
				<div class="card-photo">
					<img src="https://media.lediemquynh.com/home/avatar.jpeg" alt="Le Diem Quynh" />
				</div>
				<div class="card-info">
					<h1>Le Diem Quynh</h1>
					<p class="bio">
						I am a freelance filmmaker based in Sai Gon - Viet Nam,<br />
						working as a director, screenwriter, and assistant director.
					</p>

					<ul class="contacts">
						<li>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.71 3.35 2 2 0 0 1 3.7 1.14h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6.06 6.06l1.04-1.04a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.76 16z"/></svg>
							<span>0918400667</span>
						</li>
						<li>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
							<span>cuacan114@gmail.com</span>
						</li>
						<li>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
							<a href="https://www.facebook.com/sunmeomeo1701" target="_blank" rel="noopener">LeDiemQuynh (Quynh Sun)</a>
						</li>
						<li>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
							<a href="https://www.instagram.com/suntunxun" target="_blank" rel="noopener">Suntunxun (Quynh Sun)</a>
						</li>
					</ul>

					<p class="cta">See my work ↙</p>
				</div>
			</div>

			<nav class="category-nav">
				<a href="/film" class="cat-btn">Film</a>
				<a href="/music-video" class="cat-btn">Music Video</a>
				<a href="/commercial" class="cat-btn">Commercial</a>
			</nav>
		</main>

		<script is:inline>
			// Redirect Netlify Identity tokens to /admin/ for handling
			if (window.location.hash && (
				window.location.hash.includes('invite_token=') ||
				window.location.hash.includes('recovery_token=') ||
				window.location.hash.includes('confirmation_token=')
			)) {
				window.location.href = '/admin/' + window.location.hash;
			}

			if (window.netlifyIdentity) {
				window.netlifyIdentity.on('init', function(user) {
					if (!user) {
						window.netlifyIdentity.on('login', function() {
							document.location.href = '/admin/';
						});
					}
				});
			}
		</script>
	</body>
</html>

<style>
	:global(body) {
		background: #000;
		margin: 0;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	main {
		width: 100%;
		max-width: 900px;
		padding: 2rem 1rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	/* ── Card ── */
	.card {
		background: #fff;
		border-radius: 24px;
		padding: 2.5rem;
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 2.5rem;
		align-items: center;
		width: 100%;
		box-sizing: border-box;
	}

	/* ── Photo ── */
	.card-photo img {
		width: 220px;
		height: 280px;
		object-fit: cover;
		border-radius: 16px;
		display: block;
	}

	/* ── Info ── */
	.card-info {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	h1 {
		font-size: 2.4rem;
		font-weight: 700;
		margin: 0 0 1rem;
		color: #000;
	}

	.bio {
		font-size: 1rem;
		line-height: 1.6;
		color: #222;
		margin: 0 0 1.5rem;
	}

	/* ── Contacts ── */
	.contacts {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.6rem;
		width: 100%;
		max-width: 300px;
	}

	.contacts li {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.95rem;
		color: #111;
	}

	.contacts svg {
		width: 20px;
		height: 20px;
		flex-shrink: 0;
		color: #111;
	}

	.contacts a {
		color: #111;
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.contacts a:hover {
		color: #555;
	}

	/* ── CTA ── */
	.cta {
		font-size: 1.8rem;
		font-weight: 600;
		color: #000;
		margin: 0.5rem 0 0;
	}

	/* ── Category nav ── */
	.category-nav {
		display: flex;
		gap: 1.2rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.cat-btn {
		display: inline-block;
		padding: 0.6rem 2rem;
		background: #fff;
		color: #000;
		border-radius: 999px;
		text-decoration: none;
		font-size: 1rem;
		font-weight: 500;
		transition: background 0.2s, color 0.2s;
	}

	.cat-btn:hover {
		background: #e0e0e0;
	}

	/* ── Responsive ── */
	@media (max-width: 640px) {
		.card {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.card-photo img {
			width: 140px;
			height: 180px;
			margin: 0 auto;
		}
		.contacts {
			align-items: center;
		}
	}
</style>
