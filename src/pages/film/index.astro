---
export const prerender = true;
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const works = (await getCollection('works'))
	.filter((w: any) => w.data.category === 'film')
	.sort((a: any, b: any) => b.data.year - a.data.year);
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={`Film — ${SITE_TITLE}`} description="Short films and documentaries by Le Diem Quynh." />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>FILM</h1>
				<hr />
			</div>
			<div class="grid">
				{works.map((work: any) => (
					<a href={`/film/${work.id}`} class="card">
						<div class="thumb">
							{work.data.thumbnail
								? <img src={work.data.thumbnail} alt={work.data.title} loading="lazy" />
								: <div class="thumb-empty" />
							}
						</div>
						<p class="card-title">{work.data.title}</p>
					</a>
				))}
				{works.length === 0 && (
					<p class="empty">No films yet. Content will be added via CMS.</p>
				)}
			</div>
		</main>
	</body>
</html>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 2rem 5rem;
	}
	.page-header h1 {
		font-size: 1.4rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		margin: 1.5rem 0 1rem;
		color: #fff;
	}
	hr {
		border: none;
		border-top: 1px solid rgba(255, 255, 255, 0.2);
		margin: 0 0 2.5rem;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem 1.2rem;
	}
	.card {
		text-decoration: none;
		color: #fff;
		display: block;
	}
	.thumb {
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: #111;
		border-radius: 2px;
	}
	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 2px;
		transition: opacity 0.2s;
		display: block;
	}
	.card:hover .thumb img {
		opacity: 0.8;
	}
	.thumb-empty {
		width: 100%;
		height: 100%;
		background: #1a1a1a;
	}
	.card-title {
		margin: 0.6rem 0 0;
		font-size: 0.85rem;
		color: rgba(255, 255, 255, 0.8);
		line-height: 1.4;
	}
	.empty {
		color: rgba(255, 255, 255, 0.4);
		font-style: italic;
	}
	@media (max-width: 960px) {
		.grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
	@media (max-width: 640px) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
