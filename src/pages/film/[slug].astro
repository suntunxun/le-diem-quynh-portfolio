---
export const prerender = true;
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const all = (await getCollection('works'))
		.filter((w: any) => w.data.category === 'film')
		.sort((a: any, b: any) => b.data.year - a.data.year);

	return all.map((work: any, i: number) => {
		const total = all.length;
		const prevWork = total > 1 ? all[(i - 1 + total) % total] : null;
		const nextWork = total > 1 ? all[(i + 1) % total] : null;
		return {
			params: { slug: work.id },
			props: { work, prevWork, nextWork },
		};
	});
}

const { work, prevWork, nextWork } = Astro.props;
const { Content } = await render(work);

function getEmbedUrl(url: string): string {
	const ytMatch = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/))([a-zA-Z0-9_-]{11})/);
	if (ytMatch) return `https://www.youtube.com/embed/${ytMatch[1]}`;
	const vimeoMatch = url.match(/vimeo\.com\/(\d+)/);
	if (vimeoMatch) return `https://player.vimeo.com/video/${vimeoMatch[1]}`;
	return url;
}

const embedUrl = work.data.videoUrl ? getEmbedUrl(work.data.videoUrl) : '';
const stills: string[] = work.data.stills ?? [];
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={`${work.data.title} — ${SITE_TITLE}`} description={work.data.description} />
	</head>
	<body>
		<Header />
		<main>
			<div class="breadcrumb">
				<a href="/film">FILM</a>
				<hr />
			</div>

			<h1>{work.data.title}</h1>

			<div class="prose">
				<Content />
			</div>

			{embedUrl && (
				<div class="video-wrap">
					<iframe
						src={embedUrl}
						allowfullscreen
						allow="autoplay; encrypted-media; picture-in-picture"
						title={work.data.title}
					></iframe>
				</div>
			)}

			{stills.length > 0 && (
				<section class="stills">
					<div class="stills-grid">
						{stills.map((src: string, i: number) => (
							<button class="still-btn" data-index={String(i)} aria-label={`Still frame ${i + 1}`}>
								<img src={src} alt={`Still ${i + 1}`} loading="lazy" />
							</button>
						))}
					</div>
				</section>
			)}
		</main>

		{stills.length > 0 && (
			<div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
				<button class="lb-close" id="lb-close" aria-label="Close">&times;</button>
				<button class="lb-prev" id="lb-prev" aria-label="Previous">&#8592;</button>
				<img id="lb-img" src="" alt="" />
				<button class="lb-next" id="lb-next" aria-label="Next">&#8594;</button>
			</div>
		)}

		<footer class="project-nav">
			{prevWork
				? <a href={`/film/${prevWork.id}`} class="nav-link nav-prev">← Previous Project</a>
				: <span />
			}
			{nextWork
				? <a href={`/film/${nextWork.id}`} class="nav-link nav-next">Next Project →</a>
				: <span />
			}
		</footer>

		{stills.length > 0 && (
			<script is:inline define:vars={{ stills }}>
				const lightbox = document.getElementById('lightbox');
				const lbImg = document.getElementById('lb-img');
				let current = 0;

				function openLightbox(i) {
					current = i;
					lbImg.src = stills[current];
					lightbox.classList.add('active');
					document.body.style.overflow = 'hidden';
				}

				function closeLightbox() {
					lightbox.classList.remove('active');
					document.body.style.overflow = '';
				}

				function navigate(delta) {
					current = (current + delta + stills.length) % stills.length;
					lbImg.src = stills[current];
				}

				document.querySelectorAll('.still-btn').forEach(btn => {
					btn.addEventListener('click', () => openLightbox(parseInt(btn.dataset.index)));
				});

				document.getElementById('lb-close').addEventListener('click', closeLightbox);
				document.getElementById('lb-prev').addEventListener('click', () => navigate(-1));
				document.getElementById('lb-next').addEventListener('click', () => navigate(1));

				lightbox.addEventListener('click', e => {
					if (e.target === lightbox) closeLightbox();
				});

				document.addEventListener('keydown', e => {
					if (!lightbox.classList.contains('active')) return;
					if (e.key === 'Escape') closeLightbox();
					if (e.key === 'ArrowLeft') navigate(-1);
					if (e.key === 'ArrowRight') navigate(1);
				});
			</script>
		)}
	</body>
</html>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 2rem 3rem;
	}

	.breadcrumb {
		margin-bottom: 0;
	}
	.breadcrumb a {
		font-size: 0.8rem;
		letter-spacing: 0.12em;
		color: rgba(255, 255, 255, 0.5);
		text-decoration: none;
		font-weight: 600;
	}
	.breadcrumb a:hover {
		color: #fff;
	}
	hr {
		border: none;
		border-top: 1px solid rgba(255, 255, 255, 0.2);
		margin: 1rem 0 2rem;
	}

	h1 {
		font-size: 2.8rem;
		font-weight: 700;
		line-height: 1.15;
		margin: 0 0 1.5rem;
		color: #fff;
	}

	.prose {
		font-size: 0.85rem;
		color: rgba(255, 255, 255, 0.65);
		line-height: 1.7;
		margin-bottom: 2.5rem;
		max-width: 600px;
	}
	.prose :global(p) {
		margin: 0 0 0.4rem;
	}
	.prose :global(strong) {
		color: rgba(255, 255, 255, 0.85);
	}

	.video-wrap {
		position: relative;
		padding-bottom: 56.25%;
		height: 0;
		margin-bottom: 3rem;
	}
	.video-wrap iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: none;
		border-radius: 2px;
	}

	.stills-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.4rem;
		margin-bottom: 3rem;
	}
	.still-btn {
		all: unset;
		cursor: pointer;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: #111;
		border-radius: 2px;
		display: block;
	}
	.still-btn img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: opacity 0.2s;
	}
	.still-btn:hover img {
		opacity: 0.75;
	}

	/* Lightbox */
	.lightbox {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.96);
		z-index: 1000;
		align-items: center;
		justify-content: center;
		gap: 1rem;
	}
	.lightbox.active {
		display: flex;
	}
	#lb-img {
		max-width: 85vw;
		max-height: 85vh;
		object-fit: contain;
		border-radius: 0;
	}
	.lb-close,
	.lb-prev,
	.lb-next {
		all: unset;
		cursor: pointer;
		color: #fff;
		font-size: 2rem;
		line-height: 1;
		opacity: 0.6;
		transition: opacity 0.2s;
		position: fixed;
		z-index: 1001;
	}
	.lb-close:hover,
	.lb-prev:hover,
	.lb-next:hover {
		opacity: 1;
	}
	.lb-close {
		top: 1.5rem;
		right: 2rem;
		font-size: 2.8rem;
	}
	.lb-prev {
		left: 2rem;
		top: 50%;
		transform: translateY(-50%);
		font-size: 2.5rem;
	}
	.lb-next {
		right: 2rem;
		top: 50%;
		transform: translateY(-50%);
		font-size: 2.5rem;
	}

	/* Project footer nav */
	.project-nav {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1.5rem 2rem 3rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-top: 1px solid rgba(255, 255, 255, 0.15);
	}
	.nav-link {
		color: rgba(255, 255, 255, 0.65);
		text-decoration: none;
		font-size: 0.9rem;
		transition: color 0.2s;
	}
	.nav-link:hover {
		color: #fff;
	}

	@media (max-width: 640px) {
		h1 {
			font-size: 1.8rem;
		}
		.stills-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.lb-prev {
			left: 0.8rem;
		}
		.lb-next {
			right: 0.8rem;
		}
	}
</style>
