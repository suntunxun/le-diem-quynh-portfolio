---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="left-side">
			<div class="brand-group">
				<h2><a href="/">{SITE_TITLE}</a></h2>
				{Astro.url.pathname !== '/' && (
					<button class="back-btn" onclick="history.back()" aria-label="Go back">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</button>
				)}
			</div>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/film">Film</HeaderLink>
			<HeaderLink href="/music-video">Music Video</HeaderLink>
			<HeaderLink href="/commercial">Commercial</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0;
		background: #000;
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1.25rem;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #fff;
		font-weight: 700;
		letter-spacing: 0.08em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem var(--safe-padding);
		max-width: var(--content-max-width);
		margin: 0 auto;
		box-sizing: border-box;
	}
	.left-side {
		display: flex;
		align-items: center;
	}
	.brand-group {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 2rem;
	}
	.back-btn {
		background: none;
		border: none;
		color: #fff;
		padding: 0;
		margin: 0 0 0 1.5rem;
		cursor: pointer;
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.back-btn:hover {
		transform: scale(1.2);
	}
	.back-btn svg {
		display: block;
	}
	nav a {
		padding: 0.5em 1em;
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		font-size: 1rem;
		transition: color 0.2s;
	}
	nav a:hover,
	nav a.active {
		color: #fff;
	}
	@media (max-width: 768px) {
		.internal-links {
			display: flex;
			gap: 0.2rem;
		}
		nav a {
			padding: 0.4em 0.4em;
			font-size: 0.8rem;
		}
	}
</style>
